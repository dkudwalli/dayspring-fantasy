<section class="space-y-6">
  <section class="page-surface-dark overflow-hidden p-5 sm:p-7">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-2xl">
        <p class="eyebrow text-amber-300">History</p>
        <h1 class="mt-2 font-editorial text-3xl leading-tight sm:text-5xl">Your picks timeline</h1>
        <p class="mt-4 text-sm leading-6 text-slate-300">Track every submitted answer, see when a match moved from open to locked, and check the exact points earned after results were published.</p>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <%= link_to "Back to match center", root_path, class: class_names(button_classes(variant: :accent, size: :sm), "w-full sm:w-auto") %>
        <%= link_to "Leaderboard", leaderboards_path, class: class_names(button_classes(variant: :secondary, size: :sm), "w-full sm:w-auto") %>
      </div>
    </div>
  </section>

  <% if @predictions_by_match.empty? %>
    <section class="page-surface p-6 sm:p-8">
      <p class="eyebrow">Nothing saved yet</p>
      <h2 class="mt-2 font-editorial text-2xl text-slate-950 sm:text-3xl">You have not submitted any predictions yet.</h2>
      <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-500">Head back to the match center, answer every open question on a fixture, and your timeline will start filling out here.</p>
      <div class="mt-5">
        <%= link_to "Go to match center", root_path, class: button_classes(variant: :primary, size: :sm) %>
      </div>
    </section>
  <% else %>
    <div class="space-y-5">
      <% @predictions_by_match.each do |match, predictions| %>
        <% status =
          if predictions.any? { |prediction| prediction.prediction_question.result_published? }
            [:success, "Graded"]
          elsif match.locked?
            [:warning, "Locked"]
          else
            [:accent, "Open"]
          end %>
        <% match_points = @match_points_by_id.fetch(match.id, 0) %>

        <article class="page-surface overflow-hidden p-5 sm:p-7">
          <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
            <div>
              <p class="eyebrow"><%= format_india_time(match.starts_at, "%d %b %Y, %I:%M %p") %> IST</p>
              <h2 class="mt-2 font-editorial text-2xl text-slate-950 sm:text-3xl"><%= match.name %></h2>
              <p class="mt-2 text-sm leading-6 text-slate-500"><%= match.venue.presence || "IPL Venue" %></p>
            </div>

            <div class="flex flex-wrap gap-2">
              <span class="<%= pill_classes(tone: status.first) %>"><%= status.last %></span>
              <span class="<%= pill_classes(tone: match_points.positive? ? :accent : :neutral) %>"><%= match_points %> pts</span>
            </div>
          </div>

          <div class="mt-6 grid gap-4">
            <% predictions.each do |prediction| %>
              <% question = prediction.prediction_question %>
              <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50/80 p-4 sm:p-5">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                  <div>
                    <h3 class="text-base font-semibold text-slate-900 sm:text-lg"><%= question.prompt %></h3>
                    <p class="mt-2 text-sm leading-6 text-slate-500">
                      Your pick: <span class="font-medium text-slate-800"><%= prediction.prediction_option.label %></span>
                      <% if question.result_published? %>
                        · Correct answer: <span class="font-medium text-slate-800"><%= question.correct_option.label %></span>
                      <% end %>
                    </p>
                  </div>

                  <span class="<%= pill_classes(tone: prediction.correct? ? :success : :neutral) %>"><%= prediction.earned_points %> pts</span>
                </div>
              </div>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>
  <% end %>

  <%= render "shared/pagination",
    page: @page,
    total_pages: @total_pages,
    previous_path: (@page > 1 ? prediction_history_path(page: @page - 1) : nil),
    next_path: (@page < @total_pages ? prediction_history_path(page: @page + 1) : nil) %>
</section>
