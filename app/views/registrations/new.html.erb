<section class="auth-card">
  <p class="eyebrow">Signup</p>
  <h1>Create your account</h1>

  <% if @user.errors.any? %>
    <div class="error-box"><%= @user.errors.full_messages.to_sentence %></div>
  <% end %>

  <%= form_with model: @user, url: registration_path, class: "stack-form" do |form| %>
    <div>
      <%= form.label :email %>
      <%= form.email_field :email, required: true, class: "text-input" %>
    </div>

    <div>
      <%= form.label :password %>
      <%= form.password_field :password, required: true, class: "text-input" %>
    </div>

    <div>
      <%= form.label :password_confirmation %>
      <%= form.password_field :password_confirmation, required: true, class: "text-input" %>
    </div>

    <%= form.submit "Create account", class: "button button-primary" %>
  <% end %>
</section>
