<section class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr]">
  <section class="page-surface-dark order-2 overflow-hidden p-5 sm:p-7 lg:order-1">
    <p class="eyebrow text-amber-300">Password reset</p>
    <h1 class="mt-2 font-editorial text-3xl leading-tight sm:text-5xl">Recover access quickly.</h1>
    <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-300">Enter your work email and the app will send a reset link if an account exists. The reset token is short-lived for safety.</p>

    <div class="mt-8 rounded-[1.5rem] border border-white/10 bg-white/6 p-5">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400">Security note</p>
      <p class="mt-2 text-sm leading-6 text-slate-200">The app always shows the same confirmation message, so account existence is never exposed on this screen.</p>
    </div>
  </section>

  <section class="page-surface order-1 p-5 sm:p-8 lg:order-2">
    <p class="eyebrow">Reset password</p>
    <h2 class="mt-2 font-editorial text-3xl text-slate-950">Request a reset link</h2>
    <p class="mt-3 text-sm leading-6 text-slate-500">Use the same email address you sign in with.</p>

    <%= form_with url: password_resets_path, class: "mt-8 space-y-5" do |form| %>
      <div>
        <%= form.label :email, class: "field-label" %>
        <%= form.email_field :email, required: true, autofocus: true, class: field_classes %>
      </div>

      <div class="flex flex-col gap-3 pt-2 sm:flex-row sm:items-center sm:justify-between">
        <%= form.submit "Send reset link", class: class_names(button_classes(variant: :primary, size: :lg), "w-full sm:w-auto") %>
        <%= link_to "Back to login", new_session_path, class: "text-sm font-medium text-slate-500 hover:text-slate-900" %>
      </div>
    <% end %>
  </section>
</section>
