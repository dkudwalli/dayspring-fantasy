<section class="auth-card">
  <p class="eyebrow">Password reset</p>
  <h1>Choose a new password</h1>

  <% if @user.errors.any? %>
    <div class="error-box"><%= @user.errors.full_messages.to_sentence %></div>
  <% end %>

  <%= form_with model: @user, url: password_reset_path(params[:token]), method: :patch, class: "stack-form" do |form| %>
    <div>
      <%= form.label :password %>
      <%= form.password_field :password, required: true, class: "text-input" %>
    </div>

    <div>
      <%= form.label :password_confirmation %>
      <%= form.password_field :password_confirmation, required: true, class: "text-input" %>
    </div>

    <%= form.submit "Update password", class: "button button-primary" %>
  <% end %>
</section>
