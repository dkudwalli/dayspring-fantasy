<section class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr]">
  <section class="page-surface-dark order-2 overflow-hidden p-5 sm:p-7 lg:order-1">
    <p class="eyebrow text-amber-300">Password reset</p>
    <h1 class="mt-2 font-editorial text-3xl leading-tight sm:text-5xl">Choose a new password.</h1>
    <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-300">Once you save the new password, you can head straight back to the match center and continue from where you left off.</p>
  </section>

  <section class="page-surface order-1 p-5 sm:p-8 lg:order-2">
    <p class="eyebrow">Update password</p>
    <h2 class="mt-2 font-editorial text-3xl text-slate-950">Set a fresh password</h2>
    <p class="mt-3 text-sm leading-6 text-slate-500">Enter the new password twice to confirm the update.</p>

    <%= render "shared/form_errors", record: @user %>

    <%= form_with model: @user, url: password_reset_path(params[:token]), method: :patch, class: "mt-8 space-y-5" do |form| %>
      <div>
        <%= form.label :password, class: "field-label" %>
        <%= form.password_field :password, required: true, class: field_classes(invalid: @user.errors.include?(:password)) %>
        <% if (message = form_error_message(@user, :password)) %>
          <p class="field-error"><%= message %></p>
        <% end %>
      </div>

      <div>
        <%= form.label :password_confirmation, class: "field-label" %>
        <%= form.password_field :password_confirmation, required: true, class: field_classes(invalid: @user.errors.include?(:password_confirmation)) %>
        <% if (message = form_error_message(@user, :password_confirmation)) %>
          <p class="field-error"><%= message %></p>
        <% end %>
      </div>

      <div class="pt-2">
        <%= form.submit "Update password", class: class_names(button_classes(variant: :primary, size: :lg), "w-full sm:w-auto") %>
      </div>
    <% end %>
  </section>
</section>
