<section class="space-y-6">
  <section class="page-surface-dark overflow-hidden p-5 sm:p-7">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-2xl">
        <p class="eyebrow text-amber-300">Admin</p>
        <h1 class="mt-2 font-editorial text-3xl leading-tight sm:text-4xl">Content activity logs</h1>
        <p class="mt-4 text-sm leading-6 text-slate-300">This is the append-only history of admin-driven content changes across matches, questions, options, and publication events.</p>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <%= link_to "Prediction logs", admin_prediction_submissions_path, class: class_names(button_classes(variant: :secondary, size: :sm), "w-full sm:w-auto") %>
        <%= link_to "Matches", admin_root_path, class: class_names(button_classes(variant: :secondary, size: :sm), "w-full sm:w-auto") %>
      </div>
    </div>
  </section>

  <section class="page-surface p-5 sm:p-6">
    <p class="eyebrow">Filter logs</p>
    <h2 class="mt-2 font-editorial text-2xl text-slate-950">Search the audit trail</h2>

    <%= form_with url: admin_activity_logs_path, method: :get, class: "mt-6 space-y-5" do |form| %>
      <div class="grid gap-5 lg:grid-cols-2">
        <div>
          <%= form.label :admin, "Admin email", class: "field-label" %>
          <%= form.text_field :admin, value: params[:admin], class: field_classes %>
        </div>

        <div>
          <%= form.label :log_action, "Action", class: "field-label" %>
          <%= form.select :log_action, options_for_select(AdminAuditLog.distinct.order(:action).pluck(:action), params[:log_action]), { include_blank: "All actions" }, class: field_classes %>
        </div>
      </div>

      <div class="grid gap-5 lg:grid-cols-3">
        <div>
          <%= form.label :entity_type, "Entity", class: "field-label" %>
          <%= form.select :entity_type, options_for_select(AdminAuditLog.distinct.order(:auditable_type).pluck(:auditable_type), params[:entity_type]), { include_blank: "All entities" }, class: field_classes %>
        </div>

        <div>
          <%= form.label :date_from, "From", class: "field-label" %>
          <%= form.date_field :date_from, value: params[:date_from], class: field_classes %>
        </div>

        <div>
          <%= form.label :date_to, "To", class: "field-label" %>
          <%= form.date_field :date_to, value: params[:date_to], class: field_classes %>
        </div>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <%= form.submit "Apply filters", class: class_names(button_classes(variant: :primary, size: :md), "w-full sm:w-auto") %>
        <%= link_to "Reset", admin_activity_logs_path, class: class_names(button_classes(variant: :secondary, size: :md), "w-full sm:w-auto") %>
      </div>
    <% end %>
  </section>

  <section class="page-surface overflow-hidden">
    <div class="mobile-data-list px-4 py-4">
      <% @activity_logs.each do |log| %>
        <article class="mobile-data-card">
          <div class="mobile-data-header">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="mobile-data-label">When</p>
                <p class="mt-1 text-sm text-slate-500"><%= format_india_time(log.created_at, "%d %b %Y, %I:%M %p") %></p>
              </div>
              <span class="<%= pill_classes(tone: :info) %>"><%= log.action %></span>
            </div>

            <div>
              <h3 class="text-base font-semibold text-slate-900"><%= [log.auditable_type, log.auditable_id].compact.join("#") %></h3>
              <p class="mt-1 break-all text-sm text-slate-500"><%= log.admin_user.email %></p>
            </div>
          </div>

          <div class="pt-3">
            <div class="mobile-data-row">
              <span class="mobile-data-label">Details</span>
              <span class="mobile-data-value"><%= truncate(log.metadata.to_json, length: 140) %></span>
            </div>
          </div>
        </article>
      <% end %>
    </div>

    <div class="hidden overflow-x-auto md:block">
      <table class="data-table">
        <thead>
          <tr>
            <th>When</th>
            <th>Admin</th>
            <th>Action</th>
            <th>Entity</th>
            <th>Details</th>
          </tr>
        </thead>
        <tbody>
          <% @activity_logs.each do |log| %>
            <tr>
              <td><%= format_india_time(log.created_at, "%d %b %Y, %I:%M %p") %></td>
              <td><%= log.admin_user.email %></td>
              <td><span class="<%= pill_classes(tone: :info) %>"><%= log.action %></span></td>
              <td><%= [log.auditable_type, log.auditable_id].compact.join("#") %></td>
              <td><span class="text-slate-500"><%= truncate(log.metadata.to_json, length: 140) %></span></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="px-4 pb-4 sm:px-6 sm:pb-6">
      <%= render "shared/pagination",
        page: @page,
        total_pages: @total_pages,
        previous_path: (@page > 1 ? admin_activity_logs_path(request.query_parameters.merge(page: @page - 1)) : nil),
        next_path: (@page < @total_pages ? admin_activity_logs_path(request.query_parameters.merge(page: @page + 1)) : nil) %>
    </div>
  </section>
</section>
