<%= render "shared/form_errors", record: @match %>

<%= form_with model: [:admin, @match], class: "space-y-5" do |form| %>
  <div class="grid gap-5 md:grid-cols-2">
    <div>
      <%= form.label :team_one, class: "field-label" %>
      <%= form.text_field :team_one, class: field_classes(invalid: @match.errors.include?(:team_one)), required: true %>
    </div>

    <div>
      <%= form.label :team_two, class: "field-label" %>
      <%= form.text_field :team_two, class: field_classes(invalid: @match.errors.include?(:team_two)), required: true %>
    </div>
  </div>

  <div>
    <%= form.label :venue, class: "field-label" %>
    <%= form.text_field :venue, class: field_classes(invalid: @match.errors.include?(:venue)) %>
  </div>

  <div>
    <%= form.label :starts_at, "Match starts at", class: "field-label" %>
    <%= form.datetime_local_field :starts_at, value: format_india_time(@match.starts_at, "%Y-%m-%dT%H:%M"), class: field_classes(invalid: @match.errors.include?(:starts_at)), required: true %>
    <p class="field-hint">Enter time in India Standard Time to match what players see on the dashboard.</p>
  </div>

  <div class="pt-2">
    <%= form.submit(@match.persisted? ? "Save match" : "Create match", class: class_names(button_classes(variant: :primary, size: :md), "w-full sm:w-auto")) %>
  </div>
<% end %>
