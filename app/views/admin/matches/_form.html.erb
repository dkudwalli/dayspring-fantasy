<% if @match.errors.any? %>
  <div class="error-box"><%= @match.errors.full_messages.to_sentence %></div>
<% end %>

<%= form_with model: [:admin, @match], class: "stack-form" do |form| %>
  <div class="form-split">
    <div>
      <%= form.label :team_one %>
      <%= form.text_field :team_one, class: "text-input", required: true %>
    </div>
    <div>
      <%= form.label :team_two %>
      <%= form.text_field :team_two, class: "text-input", required: true %>
    </div>
  </div>

  <div>
    <%= form.label :venue %>
    <%= form.text_field :venue, class: "text-input" %>
  </div>

  <div>
    <%= form.label :starts_at, "Match starts at" %>
    <%= form.datetime_local_field :starts_at, value: format_india_time(@match.starts_at, "%Y-%m-%dT%H:%M"), class: "text-input", required: true %>
  </div>

  <%= form.submit class: "button button-primary" %>
<% end %>
