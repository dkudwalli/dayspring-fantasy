<section class="space-y-6">
  <section class="page-surface-dark overflow-hidden p-5 sm:p-7">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="eyebrow text-amber-300">Admin</p>
        <h1 class="mt-2 font-editorial text-3xl leading-tight sm:text-4xl"><%= @match.name %></h1>
        <p class="mt-3 text-sm leading-6 text-slate-300">
          <%= format_india_time(@match.starts_at, "%d %b %Y, %I:%M %p") %> IST
          · <%= @match.venue.presence || "IPL Venue" %>
          · <%= @match.archived? ? "Archived fixture" : "Active fixture" %>
        </p>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <%= link_to "Add question", new_admin_match_question_path(@match), class: class_names(button_classes(variant: :accent, size: :sm), "w-full sm:w-auto") %>
        <% if @match.archived? %>
          <%= button_to "Restore match", restore_admin_match_path(@match), method: :patch, class: class_names(button_classes(variant: :secondary, size: :sm), "w-full sm:w-auto"), form_class: "w-full sm:w-auto inline-block" %>
        <% else %>
          <%= button_to "Archive match", archive_admin_match_path(@match), method: :patch, class: class_names(button_classes(variant: :secondary, size: :sm), "w-full sm:w-auto"), form_class: "w-full sm:w-auto inline-block" %>
        <% end %>
      </div>
    </div>
  </section>

  <section class="grid gap-6 xl:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)]">
    <section class="page-surface p-5 sm:p-8">
      <p class="eyebrow">Fixture details</p>
      <h2 class="mt-2 font-editorial text-3xl text-slate-950">Edit match metadata</h2>
      <div class="mt-6">
        <%= render "form" %>
      </div>
    </section>

    <section class="page-surface p-5 sm:p-8">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="eyebrow">Questions</p>
          <h2 class="mt-2 font-editorial text-3xl text-slate-950">Prediction setup</h2>
        </div>
        <%= link_to "Add question", new_admin_match_question_path(@match), class: class_names(button_classes(variant: :primary, size: :sm), "w-full sm:w-auto") %>
      </div>

      <% if @match.prediction_questions.empty? %>
        <div class="mt-6 rounded-[1.5rem] border border-dashed border-slate-300 bg-slate-50/80 px-5 py-6 text-sm leading-6 text-slate-500">
          No questions exist for this fixture yet. Add the first one to make the match playable on the public dashboard.
        </div>
      <% else %>
        <div class="mt-6 space-y-4">
          <% @match.prediction_questions.ordered.each do |question| %>
            <article class="rounded-[1.75rem] border border-slate-200 bg-slate-50/80 p-4 sm:p-5">
              <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                <div>
                  <div class="flex flex-wrap gap-2">
                    <span class="<%= pill_classes(tone: question.archived? ? :warning : :success) %>"><%= question.archived? ? "Archived" : "Active" %></span>
                    <span class="<%= pill_classes(tone: question.result_published? ? :accent : :neutral) %>"><%= question.result_published? ? "Published" : "Draft" %></span>
                    <span class="<%= pill_classes(tone: :neutral) %>"><%= pluralize(question.point_value, "point") %></span>
                  </div>
                  <h3 class="mt-3 text-xl font-semibold text-slate-900"><%= question.prompt %></h3>
                  <p class="mt-2 text-sm text-slate-500">Result: <span class="font-medium text-slate-700"><%= question.correct_option&.label || "Not set yet" %></span></p>
                </div>

                <div class="flex flex-col gap-2 sm:flex-row sm:flex-wrap">
                  <%= link_to "Edit / set result", edit_admin_match_question_path(@match, question), class: class_names(button_classes(variant: :secondary, size: :sm), "w-full sm:w-auto") %>
                  <% if question.archived? %>
                    <%= button_to "Restore", restore_admin_match_question_path(@match, question), method: :patch, class: class_names(button_classes(variant: :subtle, size: :sm), "w-full sm:w-auto"), form_class: "w-full sm:w-auto inline-block" %>
                  <% else %>
                    <%= button_to "Archive", archive_admin_match_question_path(@match, question), method: :patch, class: class_names(button_classes(variant: :subtle, size: :sm), "w-full sm:w-auto"), form_class: "w-full sm:w-auto inline-block" %>
                  <% end %>
                </div>
              </div>

              <div class="mt-4 flex flex-wrap gap-2">
                <% question.options.ordered.each do |option| %>
                  <span class="<%= pill_classes(tone: option.archived? ? :warning : :neutral) %>">
                    <%= option.label %><%= option.archived? ? " · Archived" : "" %>
                  </span>
                <% end %>
              </div>
            </article>
          <% end %>
        </div>
      <% end %>
    </section>
  </section>
</section>
