<section class="space-y-6">
  <section class="page-surface-dark overflow-hidden p-5 sm:p-7">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-2xl">
        <p class="eyebrow text-amber-300">Admin</p>
        <h1 class="mt-2 font-editorial text-3xl leading-tight sm:text-5xl">Match operations</h1>
        <p class="mt-4 text-sm leading-6 text-slate-300">Create fixtures, archive old ones, and keep the season calendar current with a CSV import that matches your data pipeline.</p>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <%= link_to "Prediction logs", admin_prediction_submissions_path, class: class_names(button_classes(variant: :secondary, size: :sm), "w-full sm:w-auto") %>
        <%= link_to "Add match", new_admin_match_path, class: class_names(button_classes(variant: :accent, size: :sm), "w-full sm:w-auto") %>
      </div>
    </div>
  </section>

  <section class="grid gap-6 xl:grid-cols-[22rem_minmax(0,1fr)]">
    <section class="page-surface p-5 sm:p-6">
      <p class="eyebrow">Import schedule</p>
      <h2 class="mt-2 font-editorial text-2xl text-slate-950">Bulk load fixtures</h2>
      <p class="mt-3 text-sm leading-6 text-slate-500">Use this when the IPL schedule changes or when you are loading the season for the first time.</p>

      <%= form_with url: import_admin_matches_path, multipart: true, class: "mt-6 space-y-5" do |form| %>
        <div>
          <%= form.label :schedule_csv, "Schedule CSV", class: "field-label" %>
          <%= form.file_field :schedule_csv, name: :schedule_csv, accept: ".csv", class: field_classes %>
          <p class="field-hint">Expected headers: <code>team_one,team_two,venue,starts_at</code></p>
        </div>

        <%= form.submit "Import schedule", class: class_names(button_classes(variant: :primary, size: :md), "w-full sm:w-auto") %>
      <% end %>
    </section>

    <section class="page-surface overflow-hidden">
      <div class="flex flex-col gap-3 border-b border-slate-200 px-6 py-5 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="eyebrow">Fixtures</p>
          <h2 class="mt-2 font-editorial text-3xl text-slate-950">Manage every match</h2>
        </div>
        <p class="text-sm text-slate-500"><%= pluralize(@matches.count, "match") %> in the schedule</p>
      </div>

      <div class="mobile-data-list px-4 py-4">
        <% @matches.each do |match| %>
          <article class="mobile-data-card">
            <div class="mobile-data-header">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="mobile-data-label">Starts</p>
                  <p class="mt-1 text-sm text-slate-500"><%= format_india_time(match.starts_at, "%d %b %Y, %I:%M %p") %></p>
                </div>
                <span class="<%= pill_classes(tone: match.archived? ? :warning : :success) %>"><%= match.archived? ? "Archived" : "Active" %></span>
              </div>

              <div>
                <h3 class="text-lg font-semibold text-slate-900"><%= match.name %></h3>
                <p class="mt-1 text-sm text-slate-500"><%= match.venue.presence || "IPL Venue" %></p>
              </div>
            </div>

            <div class="pt-3">
              <div class="mobile-data-row">
                <span class="mobile-data-label">Questions</span>
                <div class="mobile-data-value">
                  <span class="<%= pill_classes(tone: :neutral) %>"><%= pluralize(match.prediction_questions.size, "question") %></span>
                </div>
              </div>

              <div class="mt-4 flex flex-col gap-3 sm:flex-row">
                <%= link_to "Edit", edit_admin_match_path(match), class: class_names(button_classes(variant: :secondary, size: :sm), "w-full sm:w-auto") %>
                <% if match.archived? %>
                  <%= button_to "Restore", restore_admin_match_path(match), method: :patch, class: class_names(button_classes(variant: :subtle, size: :sm), "w-full sm:w-auto"), form_class: "w-full sm:w-auto inline-block" %>
                <% else %>
                  <%= button_to "Archive", archive_admin_match_path(match), method: :patch, class: class_names(button_classes(variant: :subtle, size: :sm), "w-full sm:w-auto"), form_class: "w-full sm:w-auto inline-block" %>
                <% end %>
              </div>
            </div>
          </article>
        <% end %>
      </div>

      <div class="hidden overflow-x-auto md:block">
        <table class="data-table">
          <thead>
            <tr>
              <th>Starts</th>
              <th>Match</th>
              <th>Questions</th>
              <th>Status</th>
              <th class="text-right">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @matches.each do |match| %>
              <tr>
                <td><%= format_india_time(match.starts_at, "%d %b %Y, %I:%M %p") %></td>
                <td>
                  <div class="font-semibold text-slate-900"><%= match.name %></div>
                  <div class="mt-1 text-slate-500"><%= match.venue.presence || "IPL Venue" %></div>
                </td>
                <td><span class="<%= pill_classes(tone: :neutral) %>"><%= pluralize(match.prediction_questions.size, "question") %></span></td>
                <td>
                  <span class="<%= pill_classes(tone: match.archived? ? :warning : :success) %>"><%= match.archived? ? "Archived" : "Active" %></span>
                </td>
                <td>
                  <div class="flex flex-wrap justify-end gap-2">
                    <%= link_to "Edit", edit_admin_match_path(match), class: button_classes(variant: :secondary, size: :sm) %>
                    <% if match.archived? %>
                      <%= button_to "Restore", restore_admin_match_path(match), method: :patch, class: button_classes(variant: :subtle, size: :sm), form_class: "inline-block" %>
                    <% else %>
                      <%= button_to "Archive", archive_admin_match_path(match), method: :patch, class: button_classes(variant: :subtle, size: :sm), form_class: "inline-block" %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  </section>
</section>
