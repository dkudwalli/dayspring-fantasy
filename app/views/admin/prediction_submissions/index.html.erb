<section class="panel">
  <div class="panel-header">
    <div>
      <p class="eyebrow">Admin</p>
      <h1>Prediction logs</h1>
    </div>
    <%= link_to "Matches", admin_root_path, class: "button button-secondary" %>
  </div>

  <%= form_with url: admin_prediction_submissions_path, method: :get, class: "stack-form filter-form" do |form| %>
    <div class="form-split">
      <div>
        <%= form.label :user, "User email" %>
        <%= form.text_field :user, value: params[:user], class: "text-input" %>
      </div>

      <div>
        <%= form.label :match_id, "Match" %>
        <%= form.select :match_id, options_from_collection_for_select(@matches, :id, :name, params[:match_id]), { include_blank: "All matches" }, class: "text-input" %>
      </div>
    </div>

    <div class="form-split">
      <div>
        <%= form.label :action_type, "Action" %>
        <%= form.select :action_type, options_for_select([["All actions", ""], ["Created", "created"], ["Updated", "updated"]], params[:action_type]), {}, class: "text-input" %>
      </div>

      <div>
        <%= form.label :date_from, "From" %>
        <%= form.date_field :date_from, value: params[:date_from], class: "text-input" %>
      </div>

      <div>
        <%= form.label :date_to, "To" %>
        <%= form.date_field :date_to, value: params[:date_to], class: "text-input" %>
      </div>
    </div>

    <div class="panel-actions">
      <%= form.submit "Apply filters", class: "button button-primary" %>
      <%= link_to "Clear", admin_prediction_submissions_path, class: "button button-secondary" %>
    </div>
  <% end %>

  <div class="leaderboard-table">
    <div class="leaderboard-row leaderboard-head">
      <span>Time</span>
      <span>User</span>
      <span>Match</span>
      <span>Question</span>
      <span>Pick</span>
      <span>Action</span>
    </div>

    <% @prediction_submissions.each do |submission| %>
      <div class="leaderboard-row admin-log-row">
        <span><%= format_india_time(submission.submitted_at, "%d %b %Y, %I:%M %p") %></span>
        <span><%= submission.user.email %></span>
        <span><%= submission.match.name %></span>
        <span><%= submission.prediction_question.prompt %></span>
        <span><%= submission.prediction_option.label %></span>
        <span><%= submission.action_type %></span>
      </div>
    <% end %>
  </div>

  <% if @total_pages > 1 %>
    <div class="pagination-row">
      <% if @page > 1 %>
        <%= link_to "Previous", admin_prediction_submissions_path(request.query_parameters.merge(page: @page - 1)), class: "button button-secondary" %>
      <% end %>
      <span class="muted">Page <%= @page %> of <%= @total_pages %></span>
      <% if @page < @total_pages %>
        <%= link_to "Next", admin_prediction_submissions_path(request.query_parameters.merge(page: @page + 1)), class: "button button-secondary" %>
      <% end %>
    </div>
  <% end %>
</section>
