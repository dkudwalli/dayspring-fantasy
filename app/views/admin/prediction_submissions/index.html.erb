<section class="space-y-6">
  <section class="page-surface-dark overflow-hidden p-5 sm:p-7">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-2xl">
        <p class="eyebrow text-amber-300">Admin</p>
        <h1 class="mt-2 font-editorial text-3xl leading-tight sm:text-4xl">Prediction submission logs</h1>
        <p class="mt-4 text-sm leading-6 text-slate-300">Review who changed answers, on which fixture, and when a prediction record was first created versus updated.</p>
      </div>
      <%= link_to "Matches", admin_root_path, class: class_names(button_classes(variant: :secondary, size: :sm), "w-full sm:w-auto") %>
    </div>
  </section>

  <section class="page-surface p-5 sm:p-6">
    <p class="eyebrow">Filter logs</p>
    <h2 class="mt-2 font-editorial text-2xl text-slate-950">Narrow the audit trail</h2>

    <%= form_with url: admin_prediction_submissions_path, method: :get, class: "mt-6 space-y-5" do |form| %>
      <div class="grid gap-5 lg:grid-cols-2">
        <div>
          <%= form.label :user, "User email", class: "field-label" %>
          <%= form.text_field :user, value: params[:user], class: field_classes %>
        </div>

        <div>
          <%= form.label :match_id, "Match", class: "field-label" %>
          <%= form.select :match_id, options_from_collection_for_select(@matches, :id, :name, params[:match_id]), { include_blank: "All matches" }, class: field_classes %>
        </div>
      </div>

      <div class="grid gap-5 lg:grid-cols-3">
        <div>
          <%= form.label :action_type, "Action", class: "field-label" %>
          <%= form.select :action_type, options_for_select([["All actions", ""], ["Created", "created"], ["Updated", "updated"]], params[:action_type]), {}, class: field_classes %>
        </div>

        <div>
          <%= form.label :date_from, "From", class: "field-label" %>
          <%= form.date_field :date_from, value: params[:date_from], class: field_classes %>
        </div>

        <div>
          <%= form.label :date_to, "To", class: "field-label" %>
          <%= form.date_field :date_to, value: params[:date_to], class: field_classes %>
        </div>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <%= form.submit "Apply filters", class: class_names(button_classes(variant: :primary, size: :md), "w-full sm:w-auto") %>
        <%= link_to "Clear filters", admin_prediction_submissions_path, class: class_names(button_classes(variant: :secondary, size: :md), "w-full sm:w-auto") %>
      </div>
    <% end %>
  </section>

  <section class="page-surface overflow-hidden">
    <div class="mobile-data-list px-4 py-4">
      <% @prediction_submissions.each do |submission| %>
        <article class="mobile-data-card">
          <div class="mobile-data-header">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="mobile-data-label">Time</p>
                <p class="mt-1 text-sm text-slate-500"><%= format_india_time(submission.submitted_at, "%d %b %Y, %I:%M %p") %></p>
              </div>
              <span class="<%= pill_classes(tone: submission.action_type == 'created' ? :accent : :info) %>"><%= submission.action_type.capitalize %></span>
            </div>

            <div>
              <h3 class="text-base font-semibold text-slate-900"><%= submission.match.name %></h3>
              <p class="mt-1 break-all text-sm text-slate-500"><%= submission.user.email %></p>
            </div>
          </div>

          <div class="pt-3">
            <div class="mobile-data-row">
              <span class="mobile-data-label">Question</span>
              <span class="mobile-data-value"><%= submission.prediction_question.prompt %></span>
            </div>
            <div class="mobile-data-row">
              <span class="mobile-data-label">Pick</span>
              <span class="mobile-data-value"><%= submission.prediction_option.label %></span>
            </div>
          </div>
        </article>
      <% end %>
    </div>

    <div class="hidden overflow-x-auto md:block">
      <table class="data-table">
        <thead>
          <tr>
            <th>Time</th>
            <th>User</th>
            <th>Match</th>
            <th>Question</th>
            <th>Pick</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% @prediction_submissions.each do |submission| %>
            <tr>
              <td><%= format_india_time(submission.submitted_at, "%d %b %Y, %I:%M %p") %></td>
              <td><%= submission.user.email %></td>
              <td><%= submission.match.name %></td>
              <td><%= submission.prediction_question.prompt %></td>
              <td><%= submission.prediction_option.label %></td>
              <td>
                <span class="<%= pill_classes(tone: submission.action_type == 'created' ? :accent : :info) %>"><%= submission.action_type.capitalize %></span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="px-4 pb-4 sm:px-6 sm:pb-6">
      <%= render "shared/pagination",
        page: @page,
        total_pages: @total_pages,
        previous_path: (@page > 1 ? admin_prediction_submissions_path(request.query_parameters.merge(page: @page - 1)) : nil),
        next_path: (@page < @total_pages ? admin_prediction_submissions_path(request.query_parameters.merge(page: @page + 1)) : nil) %>
    </div>
  </section>
</section>
