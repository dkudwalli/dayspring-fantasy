<section class="space-y-6">
  <section class="page-surface-dark overflow-hidden p-6 sm:p-7">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="eyebrow text-amber-300">Admin</p>
        <h1 class="mt-2 font-editorial text-4xl">New question for <%= @match.name %></h1>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-300">Keep prompts short, award points deliberately, and add every answer option players should see before the fixture locks.</p>
      </div>
      <%= link_to "Back to match", edit_admin_match_path(@match), class: button_classes(variant: :secondary, size: :sm) %>
    </div>
  </section>

  <section class="page-surface p-6 sm:p-8">
    <%= render "form" %>
  </section>
</section>
