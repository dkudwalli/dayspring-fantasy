<%= render "shared/form_errors", record: @question %>

<%= form_with model: @question, url: (@question.persisted? ? admin_match_question_path(@match, @question) : admin_match_questions_path(@match)), class: "space-y-6" do |form| %>
  <section class="space-y-5">
    <div>
      <%= form.label :prompt, class: "field-label" %>
      <%= form.text_field :prompt, class: field_classes(invalid: @question.errors.include?(:prompt)), required: true %>
    </div>

    <div class="grid gap-5 md:grid-cols-2">
      <div>
        <%= form.label :point_value, class: "field-label" %>
        <%= form.number_field :point_value, class: field_classes(invalid: @question.errors.include?(:point_value)), min: 1, required: true %>
      </div>

      <% if @question.persisted? %>
        <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50/80 p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Current state</p>
          <div class="mt-3 flex flex-wrap gap-2">
            <span class="<%= pill_classes(tone: @question.archived? ? :warning : :success) %>"><%= @question.archived? ? "Archived" : "Active" %></span>
            <span class="<%= pill_classes(tone: @question.result_published? ? :accent : :neutral) %>"><%= @question.result_published? ? "Published" : "Draft" %></span>
            <span class="<%= pill_classes(tone: :neutral) %>"><%= pluralize(@question.options.count, "option") %></span>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <% if @question.new_record? %>
    <section class="rounded-[1.75rem] border border-slate-200 bg-slate-50/80 p-5">
      <p class="eyebrow">Answer options</p>
      <h2 class="mt-2 font-editorial text-2xl text-slate-950">Initial options</h2>
      <p class="mt-2 text-sm leading-6 text-slate-500">Add one option per line in the order players should see them.</p>

      <div class="mt-5">
        <%= label_tag :option_labels, "Options (one per line)", class: "field-label" %>
        <%= text_area_tag "prediction_question[option_labels]", nil, class: textarea_classes, required: true %>
      </div>
    </section>
  <% else %>
    <section class="rounded-[1.75rem] border border-slate-200 bg-slate-50/80 p-5">
      <p class="eyebrow">Result control</p>
      <h2 class="mt-2 font-editorial text-2xl text-slate-950">Draft and publish the answer</h2>
      <p class="mt-2 text-sm leading-6 text-slate-500">Save a correct option as draft first. Publishing locks the question and immediately affects scoring.</p>

      <div class="mt-5 space-y-5">
        <div>
          <%= form.label :correct_option_id, "Correct option", class: "field-label" %>
          <%= form.collection_select :correct_option_id, @question.options, :id, :label, { include_blank: "Not decided yet" }, class: field_classes(invalid: @question.errors.include?(:correct_option_id)) %>
          <% if (message = form_error_message(@question, :correct_option_id)) %>
            <p class="field-error"><%= message %></p>
          <% end %>
        </div>

        <label class="flex items-start gap-3 rounded-[1.35rem] border border-slate-200 bg-white px-4 py-4">
          <%= check_box_tag "prediction_question[publish_result]", "1", @question.result_published?, class: checkbox_classes %>
          <span>
            <span class="block text-sm font-medium text-slate-800">Publish result and lock this question</span>
            <span class="mt-1 block text-sm leading-6 text-slate-500">Players will immediately see the correct answer and any earned points.</span>
          </span>
        </label>
      </div>
    </section>

    <section class="rounded-[1.75rem] border border-slate-200 bg-slate-50/80 p-5">
      <p class="eyebrow">Option maintenance</p>
      <h2 class="mt-2 font-editorial text-2xl text-slate-950">Edit existing options</h2>

      <div class="mt-5 space-y-4">
        <% @question.options.ordered.each do |option| %>
          <div class="rounded-[1.5rem] border border-slate-200 bg-white p-5">
            <%= hidden_field_tag "prediction_question[option_updates][#{option.id}][id]", option.id %>

            <div class="grid gap-5 lg:grid-cols-[minmax(0,1fr)_10rem_10rem_auto] lg:items-end">
              <div>
                <%= label_tag "prediction_question_option_#{option.id}_label", "Label", class: "field-label" %>
                <%= text_field_tag "prediction_question[option_updates][#{option.id}][label]", option.label, class: field_classes %>
              </div>

              <div>
                <%= label_tag "prediction_question_option_#{option.id}_position", "Position", class: "field-label" %>
                <%= number_field_tag "prediction_question[option_updates][#{option.id}][position]", option.position, class: field_classes, min: 0 %>
              </div>

              <label class="flex items-center gap-3 rounded-[1.35rem] border border-slate-200 bg-slate-50 px-4 py-3">
                <%= check_box_tag "prediction_question[option_updates][#{option.id}][archived]", "1", option.archived?, class: checkbox_classes %>
                <span class="text-sm font-medium text-slate-700">Archived</span>
              </label>

              <div class="lg:text-right">
                <%= link_to "Delete", admin_match_question_option_path(@match, @question, option), data: { turbo_method: :delete, turbo_confirm: "Delete this option?" }, class: button_classes(variant: :subtle, size: :sm) %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </section>

    <section class="rounded-[1.75rem] border border-slate-200 bg-slate-50/80 p-5">
      <p class="eyebrow">Add more answers</p>
      <h2 class="mt-2 font-editorial text-2xl text-slate-950">Append new options</h2>
      <p class="mt-2 text-sm leading-6 text-slate-500">Enter one option per line. New options are added after the highest current position.</p>

      <div class="mt-5">
        <%= label_tag :new_option_labels, "New options (one per line)", class: "field-label" %>
        <%= text_area_tag "prediction_question[new_option_labels]", nil, class: textarea_classes %>
      </div>
    </section>
  <% end %>

  <div class="flex flex-wrap gap-3 pt-2">
    <%= form.submit(@question.persisted? ? "Save question" : "Create question", class: button_classes(variant: :primary, size: :md)) %>
    <%= link_to "Back to match", edit_admin_match_path(@match), class: button_classes(variant: :secondary, size: :md) %>
  </div>
<% end %>
