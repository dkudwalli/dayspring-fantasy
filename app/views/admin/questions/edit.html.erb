<section class="space-y-6">
  <section class="page-surface-dark overflow-hidden p-5 sm:p-7">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="eyebrow text-amber-300">Admin</p>
        <h1 class="mt-2 font-editorial text-3xl leading-tight sm:text-4xl">Edit question</h1>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-300">Adjust copy, scoring, answer ordering, and result publication in one place. Publishing locks this question for players immediately.</p>
      </div>
      <%= link_to "Back to match", edit_admin_match_path(@match), class: class_names(button_classes(variant: :secondary, size: :sm), "w-full sm:w-auto") %>
    </div>
  </section>

  <section class="page-surface p-5 sm:p-8">
    <%= render "form" %>
  </section>
</section>
