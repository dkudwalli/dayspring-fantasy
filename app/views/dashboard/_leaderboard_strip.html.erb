<section class="page-surface-dark overflow-hidden p-5 sm:p-7">
  <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-2xl">
      <p class="eyebrow text-amber-300">League watch</p>
      <h2 class="mt-2 font-editorial text-3xl">Top of the table</h2>
      <p class="mt-3 text-sm leading-6 text-slate-300">Scores move only after results are published, so the public table stays trustworthy and easy to scan.</p>
    </div>
  </div>

  <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    <% ranked_users.each_with_index do |user, index| %>
      <article class="rounded-[1.75rem] border border-white/10 bg-white/6 p-5">
        <div class="flex items-center justify-between gap-4">
          <span class="<%= pill_classes(tone: index.zero? ? :accent : :info) %>">#<%= index + 1 %></span>
          <span class="text-sm text-slate-300"><%= user.score %> pts</span>
        </div>
        <h3 class="mt-4 text-xl font-semibold text-white"><%= user_handle(user) %></h3>
        <p class="mt-2 text-sm text-slate-400"><%= user.email %></p>
      </article>
    <% end %>
  </div>
</section>
