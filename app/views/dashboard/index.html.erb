<section class="space-y-5 sm:space-y-6">
  <section class="page-surface-dark overflow-hidden p-5 sm:p-7">
    <div>
      <p class="eyebrow text-amber-300">Match center</p>
      <h1 class="mt-2 font-editorial text-3xl leading-tight sm:text-5xl"><%= @selected_date.strftime("%A, %-d %B %Y") %></h1>
      <p class="mt-4 max-w-3xl text-sm leading-6 text-slate-300">
        Review the fixture for the day, lock your answer before play starts, and return after results are published to track the table.
      </p>
    </div>
  </section>

  <section class="grid gap-5 xl:grid-cols-[20rem_minmax(0,1fr)] xl:gap-6">
    <aside class="space-y-5 sm:space-y-6">
      <section class="page-surface p-5 sm:p-6">
        <p class="eyebrow">Selected day</p>
        <h2 class="mt-2 font-editorial text-2xl text-slate-950 sm:text-3xl"><%= @selected_date.strftime("%a, %-d %b") %></h2>
        <p class="mt-3 text-sm leading-6 text-slate-500">Choose another fixture day from the schedule navigator to jump across the season without leaving the page.</p>
      </section>

      <%= render "metrics", selected_date: @selected_date, current_user_rank: @current_user_rank %>

      <section class="page-surface p-5 sm:p-6">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="eyebrow">Schedule</p>
            <h2 class="mt-2 font-editorial text-2xl text-slate-950">Jump to a match day</h2>
          </div>

          <% if @total_schedule_pages.positive? %>
            <div class="flex items-center gap-2">
              <% if @schedule_page > 1 %>
                <%= link_to "←", root_path(date: @selected_date, page: @schedule_page - 1), class: button_classes(variant: :secondary, size: :sm) %>
              <% else %>
                <span class="inline-flex items-center justify-center rounded-full border border-slate-200 px-3 py-2 text-sm text-slate-400">←</span>
              <% end %>
              <% if @schedule_page < @total_schedule_pages %>
                <%= link_to "→", root_path(date: @selected_date, page: @schedule_page + 1), class: button_classes(variant: :secondary, size: :sm) %>
              <% else %>
                <span class="inline-flex items-center justify-center rounded-full border border-slate-200 px-3 py-2 text-sm text-slate-400">→</span>
              <% end %>
            </div>
          <% end %>
        </div>

        <% if @visible_dates.any? %>
          <div class="mt-5 grid grid-cols-2 gap-3">
            <% @visible_dates.each do |date| %>
              <%= link_to root_path(date: date, page: @schedule_page), class: class_names(
                "rounded-[1.35rem] border px-3 py-3 text-left transition sm:px-4",
                date == @selected_date ?
                  "border-slate-950 bg-slate-950 text-white shadow-lg shadow-slate-950/10" :
                  "border-slate-200 bg-slate-50/80 text-slate-700 hover:border-slate-300 hover:bg-white"
              ) do %>
                <span class="block text-xs font-semibold uppercase tracking-[0.22em] <%= date == @selected_date ? 'text-slate-300' : 'text-slate-500' %>"><%= date.strftime("%a") %></span>
                <strong class="mt-2 block text-2xl font-semibold"><%= date.strftime("%d") %></strong>
                <span class="mt-1 block text-sm <%= date == @selected_date ? 'text-slate-300' : 'text-slate-500' %>"><%= date.strftime("%b %Y") %></span>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="mt-5 rounded-[1.5rem] border border-dashed border-slate-300 bg-slate-50/80 px-5 py-6 text-sm leading-6 text-slate-500">
            No scheduled match dates are available yet. Add matches from the admin area and they will appear here.
          </div>
        <% end %>
      </section>
    </aside>

    <div class="space-y-5 sm:space-y-6">
      <% if @matches.empty? %>
        <section class="page-surface p-6 sm:p-8">
          <p class="eyebrow">Nothing to lock</p>
          <h2 class="mt-2 font-editorial text-2xl text-slate-950 sm:text-3xl">No matches on <%= @selected_date.strftime("%-d %b %Y") %></h2>
          <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-500">This day is currently empty. Import or create a fixture from the admin area and it will show up here immediately.</p>
          <% if current_user&.admin? %>
            <div class="mt-5">
              <%= link_to "Add a match", new_admin_match_path, class: button_classes(variant: :primary, size: :sm) %>
            </div>
          <% end %>
        </section>
      <% end %>

      <% @matches.each do |match| %>
        <%= render "match_card", match: match, predictions_by_question_id: @predictions_by_question_id %>
      <% end %>

      <%= render "leaderboard_strip", ranked_users: @ranked_users %>
    </div>
  </section>
</section>
